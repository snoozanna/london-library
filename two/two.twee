:: scene5a-text [nobr]
<<timed 1s>>
<p>I need you all to check in the Stacks for the manuscript.</p>
<p>Find where Arthur Conan Doyle’s books are and write down the name of his 1907 ‘Through the Magic …’ and show it to your handler.  </p>
<br/>
<<include "pwScene5a">>

<</timed>>

:: pwScene5a [nobr]
<<set $codeword to "">>  /* ensure it's blank so the placeholder shows */

<div class="codeinput">
  <<textbox "$codeword" "">>

  <div class="input-btn">
  <<button "Enter">>
    <<set $codeword to $codeword.toUpperCase().trim()>>

    /* Correct */
    <<if $codeword is "DOOR">>
      <<replace "#coderesult">><span>Correct!</span>
      <</replace>>
     <<timed 2s>>
<<goto $nextpass>>
          <</timed>>
    <<elseif $codeword isnot "">>
      /* Incorrect (non-empty) */
      <<replace "#coderesult">><span>Try again.</span><</replace>>
      <<timed 1.5s>><<replace "#coderesult">><</replace>><</timed>>
    <</if>>
  <</button>>
  </div>
</div>
<br/>
<div id="coderesult"></div>

<<done>><<set $e to setup.addPlaceholder()>><</done>>

