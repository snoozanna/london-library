:: _templateIntro[nobr]
<<addclass "body" "intro">>
<main>
<div id="audio"></div>
    <div id="msgMount">
        <<if $pass>>
             <<set $uniqueContent to $pass+"-text">>
            <<include $uniqueContent>>
            <div class="btn-container" id="btnContainer">
            </div>
        <<else>>
            No content provided.
        <</if>>
        </div>
  
</main> 
<<include "navbuttonsb">>

:: _templateStory [nobr]

<main>
<div id="audio"></div>
    <div id="msgMount"> </div>
        <<if $pass>>
      
             <<set $uniqueContent to $pass+"-text">>
            <<silently>>
            <<timed 0.1s>>
            <<append "#msgMount">>
              <<include $uniqueContent>>
              <</append>>
              <</timed>>
            <</silently>>
               <div class="btn-container" id="btnContainer">
            </div>
        <<else>>
            No content provided.
        <</if>>

</main>
<<include "navbuttonsb">>


