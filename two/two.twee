<main class="moveOn">
<h1>Madame De Tencin</h1>
 <div class="btn-container" id="btnContainer">
 <<include "sealButton">>
</div>
</main>

:: scene10a-moveOn [nobr]
<<set $prevpass to "scene10a-seal">>
<<set $pass to "scene10a-moveOn">>
<<set $nextpass to "scene11">>
<<audio ":all" "stop">>
<audio src="" autoplay>Audio is not supported on your device</audio>
<<include "_templateMoveOn">>


:: scene11 [nobr]
<<set $prevpass to "scene10a-seal">>
<<set $pass to "scene11">>
<<set $nextpass to "scene11a">>
<<audio ":all" "stop">>
<audio src="" autoplay>Audio is not supported on your device</audio>
<<include "_templateStory">>

:: scene11-text [nobr]
 <<timed 0.1s>>
    <<append "#audio">><<if $userchoices.audioOn is true>><audio src="../assets/audio/LL_Proto11.mp3" autoplay id="bgAudio">Audio is not supported on your device</audio><</if>><</append>>
    <</timed>>
<p class="bold">Scene 11 </p>
<div id="msgMount">
<div class="inline-img-wrapper">
<img src="../assets/img/audio.png">
</div>
</div>
<<timed 42s>>
    <<replace "#msgMount">>
     <p class="bold">Break the code in the Madame De Tencin painting using your codebreaker and write it below. </p>
   <<include "pwScene11">>
    <</replace>>
<</timed>>




:: pwScene11 [nobr]
<<set $codeword to "">>  /* ensure it's blank so the placeholder shows */

<div class="codeinput">
  <<textbox "$codeword" "">>

  <div class="input-btn">
  <<button "Enter">>
    <<set $codeword to $codeword.toUpperCase().trim()>>

    /* Correct */
    <<if $codeword is "INANE">>
      <<replace "#coderesult">><span>Correct!</span>
      <</replace>>
     
   <<timed 3s>><<goto $nextpass>><</timed>>
    <<elseif $codeword isnot "">>
      /* Incorrect (non-empty) */
      <<replace "#coderesult">><span>Try again.</span><</replace>>
      <<timed 1.5s>><<replace "#coderesult">><</replace>><</timed>>
    <</if>>
  <</button>>
  </div>
</div>
<br/>
<div id="coderesult"></div>


:: scene11a [nobr]
<<set $prevpass to "pwScene11">>
<<set $pass to "scene11a">>
<<set $nextpass to "scene11a-seal">>
<<audio ":all" "stop">>
<audio src="" autoplay>Audio is not supported on your device</audio>
<<include "_templateStory">>

:: scene11a-text [nobr]

<p>It’s an anagram!</p>
<p>Rejig it to find the word.</p>

<<timed 1s>>
   <<include "pwScene11a">>
<</timed>>


:: pwScene11a [nobr]
<<set $codeword to "">>  /* ensure it's blank so the placeholder shows */

<div class="codeinput">
  <<textbox "$codeword" "">>

  <div class="input-btn">
  <<button "Enter">>
    <<set $codeword to $codeword.toUpperCase().trim()>>

    /* Correct */
    <<if $codeword is "ANNIE">>
      <<replace "#coderesult">><span>Correct!</span>
      <</replace>>
     <<timed 2s>>
 <<goto $nextpass>>
      <</timed>>
    <<elseif $codeword isnot "">>
      /* Incorrect (non-empty) */
      <<replace "#coderesult">><span>Try again.</span><</replace>>
      <<timed 1.5s>><<replace "#coderesult">><</replace>><</timed>>
    <</if>>
  <</button>>
  </div>
</div>
<br/>
<div id="coderesult"></div>

:: scene11a-seal [nobr]
<<set $prevpass to "scene11a">>
<<set $pass to "scene11a-seal">>
<<set $nextpass to "scene11-moveOn">>
<<audio ":all" "stop">>
<<addclass "body" "moveOn">>
<audio src="" autoplay>Audio is not supported on your device</audio>
<main class="moveOn">
<h1>Annie</h1>
 <div class="btn-container" id="btnContainer">
 <<include "sealButton">>
</div>
</main>

:: scene11-moveOn [nobr]
<<set $prevpass to "scene11a-seal">>
<<set $pass to "scene11-moveOn">>
<<set $nextpass to "scene12">>
<<audio ":all" "stop">>
<audio src="" autoplay>Audio is not supported on your device</audio>
<<include "_templateMoveOn">>


:: scene12 [nobr]
<<set $prevpass to "scene11a-seal">>
<<set $pass to "scene12">>
<<set $nextpass to "">>
<<audio ":all" "stop">>
<audio src="" autoplay>Audio is not supported on your device</audio>
<<include "_templateStory">>

:: scene12-text [nobr]
<<timed 0.1s>>
    <<append "#audio">><<if $userchoices.audioOn is true>><audio src="../assets/audio/LL_Proto12.mp3" autoplay id="bgAudio">Audio is not supported on your device</audio><</if>><</append>>
    <</timed>>
<p class="bold">Scene 12 </p>
<div id="msgMount">
<div class="inline-img-wrapper">
<img src="../assets/img/audio.png">
</div>
</div>
<<timed 282s>>
    <<replace "#msgMount">>
     <p class="bold">It’s up to you...</p>
  <div class="choice-container">
  <div class="choice-item">
       <span>Sherlock Holmes lives. Today becomes a story.</span>
    <<button "WRITE IT">>
      <<goto "scene13a">>
      <</button>>
  </div>
   <div class="choice-item">
       <span>"The Final Problem" is published. Today is yours alone.</span>
    <<button " LET HIM FALL">>
      <<goto "scene13b">>
      <</button>>
  </div>
    <</replace>>
<</timed>>





:: scene13a [nobr]
<<set $prevpass to "scene11a-seal">>
<<set $pass to "scene13a">>
<<set $nextpass to "end">>
<<audio ":all" "stop">>
<audio src="" autoplay>Audio is not supported on your device</audio>
<<include "_templateStory">>


:: scene13a-text [nobr]
<<timed 0.1s>>
    <<append "#audio">><<if $userchoices.audioOn is true>><audio src="../assets/audio/LL_Proto13a.mp3" autoplay id="bgAudio">Audio is not supported on your device</audio><</if>><</append>>
    <</timed>>

<div id="msgMount">
<div class="inline-img-wrapper">
<img src="../assets/img/audio.png">
</div>
</div>
<<timed 50s>>
     <<addclass "body" "moveOn">>
    <<replace "#msgMount">>
    <h1>Free Annie</h1>
 <div class="btn-container" id="btnContainer">
 <<include "sealButton">>
 </div>

    <</replace>>
<</timed>>


:: scene13b [nobr]
<<set $prevpass to "scene12">>
<<set $pass to "scene13b">>
<<set $nextpass to "end">>
<<audio ":all" "stop">>
<audio src="" autoplay>Audio is not supported on your device</audio>
<<include "_templateStory">>

:: scene13b-text [nobr]
<<timed 0.1s>>
    <<append "#audio">><<if $userchoices.audioOn is true>><audio src="../assets/audio/LL_Proto13b.mp3" autoplay id="bgAudio">Audio is not supported on your device</audio><</if>><</append>>
    <</timed>>

<div id="msgMount">
<div class="inline-img-wrapper">
<img src="../assets/img/audio.png">
</div>
</div>
<<timed 68s>>
   <<replace "#msgMount">>
    <<addclass "body" "moveOn">>
    <h1>Arrest Annie</h1>
 <div class="btn-container" id="btnContainer">
 <<include "sealButton">>
 </div>

    <</replace>>
<</timed>>



:: end [nobr]
<<set $prevpass to "scene12">>
<<set $pass to "end">>
<<set $nextpass to "end">>
<<audio ":all" "stop">>
<audio src="" autoplay>Audio is not supported on your device</audio>
<<include "end-text">>


:: end-text [nobr]
<<audio ":all" "stop">>
<<addclass "body" "moveOn">>
<main>
    <h1>The End </h1> 
        <div class="btn-container">
      
            <<button "Start again">>
                <<script>>
                Engine.restart()
                <</script>>
                <</button>>
        </div>
</main>
<<include "navbuttonsend">>