:: scene2-text [nobr]
<p class="bold">Scene 2 </p>

<<timed 3s>>
    <p>Head up the stairs with the green carpet – walk up to flights of stairs – on the right hand side until you get to the entrance to the Reading Room.</p>
<p>When there click your handler will give you permission to press below</p>

    <</timed>>

<<timed 5s>>
    <<append "#btnContainer">>
    <<button "Next">>
            <<goto $nextpass>>
        <</button>>
   /* <<include "navbuttons">> */
    <</append>>
    
<</timed>>



:: pwScene3 [nobr]
<<set $codeword to "">>  /* ensure it's blank so the placeholder shows */

<div class="codeinput">
  <<textbox "$codeword" "">>

  <div class="input-btn">
  <<button "Enter">>
    <<set $codeword to $codeword.toUpperCase().trim()>>

    /* Correct */
    <<if $codeword is "SHERLOCK HOLMES">>
      <<replace "#coderesult">><span>Correct!</span>
      <</replace>>
     
       <<replace "#btnContainer">>
        <p>Sherlock Holmes handwritten image</p>
        <<include "sealButton">>
      <</replace>>
    <<elseif $codeword isnot "">>
      /* Incorrect (non-empty) */
      <<replace "#coderesult">><span>Try again.</span><</replace>>
      <<timed 1.5s>><<replace "#coderesult">><</replace>><</timed>>
    <</if>>
  <</button>>
  </div>
</div>
<br/>
<div id="coderesult"></div>

<<done>><<set $e to setup.addPlaceholder()>><</done>>

