<<include "_templateStory">>

:: scene1-text [nobr]
<p class="bold">Scene 1 </p>

<<timed 3s>>
<p class="bold">What is the name of the city on the dial of the library clock? </p>
<<include "pwScene1">>
    
<</timed>>

:: pwScene1 [nobr]
<<set $codeword to "">>  /* ensure it's blank so the placeholder shows */

<div class="codeinput">
  <<textbox "$codeword" "">>

  <div class="input-btn">
  <<button "Enter">>
    <<set $codeword to $codeword.toUpperCase().trim()>>

    /* Correct */
    <<if $codeword is "LONDON">>
      <<replace "#coderesult">><span>Correct!</span>
      <</replace>>
     
      <<timed 3s>><<goto $nextpass>><</timed>>
    <<elseif $codeword isnot "">>
      /* Incorrect (non-empty) */
      <<replace "#coderesult">><span>Try again.</span><</replace>>
      <<timed 1.5s>><<replace "#coderesult">><</replace>><</timed>>
    <</if>>
  <</button>>
  </div>
</div>
<br/>
<div id="coderesult"></div>

<<done>><<set $e to setup.addPlaceholder()>><</done>>

